// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}


model Kiosk {
  id            String      @id @default(uuid())
  deviceId      String      @unique // Hardware serial ba unique ID
  name          String // Kiosk-er ekta naam (e.g. "Library-01")
  location      String?
  status        KioskStatus @default(ONLINE)
  qrCodeUrl     String? // Backend theke generate kora QR link
  paperLevel    Int         @default(100) // Percentage (0-100)
  inkLevel      Int         @default(100) // Percentage (0-100)
  lastHeartbeat DateTime    @default(now())

  orders    Order[] // One-to-many relationship
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum KioskStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  OUT_OF_PAPER
}

model Order {
  id          String @id @default(uuid())
  orderNumber Int    @unique @default(autoincrement())

  // associating entities
  kioskId String
  kiosk   Kiosk  @relation(fields: [kioskId], references: [deviceId])

  // user who placed the order (optional)
  userId    String?
  userEmail String?
  userPhone String?

  // where the uploaded file is stored on backend/FS
  filePath String?

  // File details (possibly filled later)
  fileUrl   String? // Cloud ba local storage link
  fileName  String?
  pageCount Int?
  copyCount Int     @default(1)
  isColor   Boolean @default(false)

  // Money details
  totalAmount Float? // Mot koto taka bill holo
  paidAmount  Float @default(0) // Koto taka ekhon porjonto dise

  // Statuses
  paymentStatus PaymentStatus @default(PENDING)
  printStatus   PrintStatus   @default(WAITING_FOR_PAYMENT)

  payments Payment[] // Payment details tracking

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  PARTIAL // Jodi keu kichu taka dey kintu purota na
  COMPLETED
  FAILED
  REFUNDED
}

enum PrintStatus {
  WAITING_FOR_PAYMENT
  QUEUED // Taka deoa shesh, ekhon line-e ache
  PRINTING // Machine ekhon print korche
  COMPLETED // Hat-e peye gese
  FAILED // Kono karone print hoy nai
}

model Payment {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  amount        Float // Ei specific transaction-e koto dise
  method        PaymentMethod
  transactionId String?       @unique // bKash/Nagad ID ba hardware signal ID

  createdAt DateTime @default(now())
}

enum PaymentMethod {
  CASH // Bill Acceptor theke deoa taka
  BKASH
  NAGAD
  SSLCOMMERZ
}
